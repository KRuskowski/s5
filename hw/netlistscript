# Ports 1-5: KSZ PHY -> LPJG0926HENL PoE+ GbE MagJack.
# Integrated magnetics + LEDs + PoE center taps in one part.
# Each port uses all 4 pairs = full 1000BASE-T.
#
# LPJG0926HENL pinout (20 pins):
#   1=TD1+, 2=TD1-, 3=TD2+, 6=TD2-, 7=TD3+, 8=TD3-,
#   9=TD4+, 10=TD4-  (chip/PHY side MDI pairs)
#   4,5 = chip-side center taps (100nF to GND)
#   11=VC1, 12=VC2   (line-side CT, PoE V+)
#   13=VC3, 14=VC4   (line-side CT, PoE return)
#   15=GRN+, 16=GRN- (green LED)
#   17=YEL+, 18=YEL- (yellow LED)
#   S1,S2 = shield
# ============================================================
# KSZ MDI pins per port, pairs 1-4:
KSZ_PORT_MDI = {
  1: [(1, 2),   (4, 5),   (6, 7),   (8, 9)],
  2: [(12, 13), (15, 16), (17, 18), (20, 21)],
  3: [(24, 25), (26, 27), (28, 29), (31, 32)],
  4: [(34, 35), (37, 38), (39, 40), (42, 43)],
  5: [(112, 113), (115, 116), (117, 118), (120, 121)],
}
# MagJack chip-side MDI pin pairs (TD1..TD4 +/-)
MJ_P = [1, 3, 7, 9]    # TD1+, TD2+, TD3+, TD4+
MJ_N = [2, 6, 8, 10]   # TD1-, TD2-, TD3-, TD4-
PAIR = ['A', 'B', 'C', 'D']

# KSZ LED pins per port
KSZ_LEDS = {
  1: (105, 106), 2: (91, 92), 3: (88, 89),
  4: (85, 86),   5: (102, 103),
}

# PoE supply nets per port (from PSE FET section below)
poe_vp = {p: Net(f'POE_VP_{p}') for p in range(1, 6)}

for pn in range(1, 6):
  j = Part(
    tool=SKIDL, name='LPJG0926HENL', ref_prefix='J', dest=NETLIST,
    footprint='connectors:LPJG0926HENL',
    pins=[Pin(num=str(i), name=f'P{i}', func=Pin.types.PASSIVE)
          for i in range(1, 19)]
         + [Pin(num='S1', name='SH1', func=Pin.types.PASSIVE),
            Pin(num='S2', name='SH2', func=Pin.types.PASSIVE)])
  j.ref = f'J{pn + 1}'   # J2..J6

  # KSZ PHY pairs -> magjack chip-side MDI
  for idx in range(4):
    pp, pm = KSZ_PORT_MDI[pn][idx]
    np_ = Net(f'P{pn}_{PAIR[idx]}P')
    nm_ = Net(f'P{pn}_{PAIR[idx]}N')
    U1[pp] += np_; U1[pm] += nm_
    j[MJ_P[idx]] += np_; j[MJ_N[idx]] += nm_

  # Chip-side center taps (pins 4,5): 100nF to GND
  ct1 = Net(f'P{pn}_CT1'); j[4] += ct1
  c = cap('100nF'); c[1] += ct1; c[2] += gnd
  ct2 = Net(f'P{pn}_CT2'); j[5] += ct2
  c = cap('100nF'); c[1] += ct2; c[2] += gnd

  # Line-side center taps: PoE Mode A
  # VC1+VC2 (pins 11,12) -> 48V from PSE
  # VC3+VC4 (pins 13,14) -> return (GND)
  j[11] += poe_vp[pn]; j[12] += poe_vp[pn]
  j[13] += gnd;        j[14] += gnd

  # LEDs: KSZ LED0 -> green (pins 15,16),
  #        KSZ LED1 -> yellow (pins 17,18)
  # KSZ LED pins are active-low open-drain sinks.
  # MagJack LEDs have internal limiting? No — add series R.
  led0, led1 = KSZ_LEDS[pn]
  grn = Net(f'P{pn}_GRN'); U1[led0] += grn
  r = res('150'); r[1] += vdd33; r[2] += j[15]  # GRN anode
  j[16] += grn                                   # GRN cathode
  yel = Net(f'P{pn}_YEL'); U1[led1] += yel
  r = res('150'); r[1] += vdd33; r[2] += j[17]  # YEL anode
  j[18] += yel                                   # YEL cathode

  # Shield
  j['S1'] += gnd; j['S2'] += gnd

