tc('USB0-DP', usb_dp); tc('USB0-DM', usb_dm)

# --- T113 SDC0 (PF bank) -> micro SD card slot ---
# Standard micro SD pinout (SD mode, 4-bit):
#   1=DAT2, 2=DAT3/CD, 3=CMD, 4=VDD, 5=CLK,
#   6=VSS, 7=DAT0, 8=DAT1, 9=CD(detect), 10/11=shield
sd_clk = Net('SD_CLK')
sd_cmd = Net('SD_CMD')
sd_d0  = Net('SD_D0')
sd_d1  = Net('SD_D1')
sd_d2  = Net('SD_D2')
sd_d3  = Net('SD_D3')
tc('PF0', sd_d1)    # SDC0_D1
tc('PF1', sd_d0)    # SDC0_D0
tc('PF2', sd_clk)   # SDC0_CLK
tc('PF3', sd_cmd)   # SDC0_CMD
tc('PF4', sd_d3)    # SDC0_D3
tc('PF5', sd_d2)    # SDC0_D2

J_SD = Part(
  tool=SKIDL, name='microSD', ref_prefix='J', dest=NETLIST,
  footprint='Connector_Card:'
            'microSD_HC_Molex_104031-0811',
  pins=[Pin(num=str(i), name=f'P{i}', func=Pin.types.PASSIVE)
        for i in range(1, 12)])
J_SD.ref = 'J8'
J_SD[1]  += sd_d2     # DAT2
J_SD[2]  += sd_d3     # DAT3/CD
J_SD[3]  += sd_cmd    # CMD
J_SD[4]  += vdd33     # VDD
J_SD[5]  += sd_clk    # CLK
J_SD[6]  += gnd       # VSS
J_SD[7]  += sd_d0     # DAT0
J_SD[8]  += sd_d1     # DAT1
J_SD[9]  += Net('SD_CD')   # card detect (optional GPIO)
J_SD[10] += gnd       # shield
J_SD[11] += gnd       # shield
# ESD protection: 100nF on VDD
decouple(vdd33, gnd, 1)

# --- T113 watchdog kick GPIO (PB6) ---
wdi = Net('WDI'); tc('PB6', wdi)

# ============================================================
# W25N02 SPI NAND boot flash (256MB) -- SOIC-8
# Shared SPI0 bus; flash CS on T113 PC3 (SPI0-CS0),
# KSZ CS on PB4 (GPIO).
# ============================================================
U8 = Part(
  tool=SKIDL, name='W25N02JWZEIF', ref_prefix='U', dest=NETLIST,
  footprint='Package_SO:SOIC-8_3.9x4.9mm_P1.27mm',
  pins=[
    Pin(num='1', name='CS',   func=Pin.types.INPUT),
    Pin(num='2', name='DO',   func=Pin.types.OUTPUT),
    Pin(num='3', name='WP',   func=Pin.types.INPUT),
    Pin(num='4', name='GND',  func=Pin.types.PWRIN),
    Pin(num='5', name='DI',   func=Pin.types.INPUT),
    Pin(num='6', name='CLK',  func=Pin.types.INPUT),
    Pin(num='7', name='HOLD', func=Pin.types.INPUT),
    Pin(num='8', name='VCC',  func=Pin.types.PWRIN),
  ])
U8.ref = 'U8'
# flash_cs is wired to T113 SPI0-CS0 (PC3) in the T113 section.
U8[1] += flash_cs
U8[2] += spi_miso
U8[4] += gnd
U8[5] += spi_mosi
U8[6] += spi_clk
U8[8] += vdd33
fw = Net('FLASH_WP'); r = res('10k'); r[1] += vdd33; r[2] += fw
U8[3] += fw
fh = Net('FLASH_HOLD'); r = res('10k'); r[1] += vdd33; r[2] += fh
U8[7] += fh
decouple(vdd33, gnd, 1)

