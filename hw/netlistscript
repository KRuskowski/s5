# Fault/alarm LED (red) on a T113 GPIO (active low)
fault = Net('LED_FAULT'); an = Net('LED_FAULT_A')
r = res('270'); d = led()
r[1] += vdd33; r[2] += an; d[1] += an; d[2] += fault
tc('PE4', fault)

