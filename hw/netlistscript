def tps23861(ref_des):
  u = Part(
    tool=SKIDL, name='TPS23861', ref_prefix='U', dest=NETLIST,
    footprint='Package_SO:TSSOP-28_4.4x9.7mm_P0.65mm',
    pins=[
      Pin(num='1',  name='VDD',    func=Pin.types.PWRIN),
      Pin(num='2',  name='RESET',  func=Pin.types.INPUT),
      Pin(num='3',  name='SCL',    func=Pin.types.INPUT),
      Pin(num='4',  name='SDAI',   func=Pin.types.INPUT),
      Pin(num='5',  name='SDAO',   func=Pin.types.OPENCOLL),
      Pin(num='6',  name='INT',    func=Pin.types.OPENCOLL),
      Pin(num='7',  name='DGND',   func=Pin.types.PWRIN),
      Pin(num='8',  name='SEN3',   func=Pin.types.INPUT),
      Pin(num='9',  name='DRAIN3', func=Pin.types.INPUT),
      Pin(num='10', name='GATE3',  func=Pin.types.OUTPUT),
      Pin(num='11', name='KSENSB', func=Pin.types.INPUT),
      Pin(num='12', name='SEN4',   func=Pin.types.INPUT),
      Pin(num='13', name='DRAIN4', func=Pin.types.INPUT),
      Pin(num='14', name='GATE4',  func=Pin.types.OUTPUT),
      Pin(num='15', name='SEN1',   func=Pin.types.INPUT),
      Pin(num='16', name='DRAIN1', func=Pin.types.INPUT),
      Pin(num='17', name='GATE1',  func=Pin.types.OUTPUT),
      Pin(num='18', name='KSENSA', func=Pin.types.INPUT),
      Pin(num='19', name='SEN2',   func=Pin.types.INPUT),
      Pin(num='20', name='DRAIN2', func=Pin.types.INPUT),
      Pin(num='21', name='GATE2',  func=Pin.types.OUTPUT),
      Pin(num='22', name='AGND',   func=Pin.types.PWRIN),
      Pin(num='23', name='A3',     func=Pin.types.INPUT),
      Pin(num='24', name='SHTDWN', func=Pin.types.INPUT),
      Pin(num='25', name='AIN',    func=Pin.types.INPUT),
      Pin(num='26', name='AOUT',   func=Pin.types.OUTPUT),
      Pin(num='27', name='NC',     func=Pin.types.NOCONNECT),
      Pin(num='28', name='VPWR',   func=Pin.types.PWRIN),
    ])
  u.ref = ref_des
  return u

# Shared PSE I2C bus (managed by H3 TWI)
i2c_sda = Net('PSE_I2C_SDA')
i2c_scl = Net('PSE_I2C_SCL')

def wire_pse_common(u, a3_to_gnd):
  u[1]  += vdd33      # VDD
  u[7]  += gnd        # DGND
  u[22] += gnd        # AGND
  u[28] += vbus48      # VPWR
  decouple(vdd33, gnd, 1)
  c = cap('100nF', 'Capacitor_SMD:C_0805_2012Metric')
  c[1] += vbus48; c[2] += gnd
  rst = Net(f'{u.ref}_RESET')
  u[2] += rst
  r = res('10k'); r[1] += vdd33; r[2] += rst
  u[3] += i2c_scl; u[4] += i2c_sda; u[5] += i2c_sda
  u[6] += Net(f'{u.ref}_INT_N')
  u[23] += gnd if a3_to_gnd else vdd33  # address select
  u[24] += vdd33      # SHTDWN disabled
  u[25] += Net(f'{u.ref}_AIN')
  u[26] += Net(f'{u.ref}_AOUT')

# Per-channel FET circuit
def wire_pse_channel(u, sen_pin, drain_pin, gate_pin, vp_net,
                     qref):
  gate = Net(f'{u.ref}_GATE{gate_pin}')
  drain_s = Net(f'{u.ref}_DRAIN{drain_pin}')
  src = Net(f'{u.ref}_SRC{sen_pin}')
  sen = Net(f'{u.ref}_SEN{sen_pin}')
  u[gate_pin] += gate
  u[drain_pin] += drain_s
  u[sen_pin] += sen
  q = nfet(qref)
  q[1] += gate; q[2] += vbus48; q[3] += src
  r = res('47'); r[1] += vbus48; r[2] += drain_s
  # 0.25 ohm sense resistor
  _rref[0] += 1
  r = Part(
    tool=SKIDL, name='R', ref_prefix='R', dest=NETLIST,
    value='0.25', footprint='Resistor_SMD:R_0805_2012Metric',
    pins=[Pin(num='1', name='1', func=Pin.types.PASSIVE),
          Pin(num='2', name='2', func=Pin.types.PASSIVE)])
  r.ref = f'R{_rref[0]}'
  r[1] += src; r[2] += vp_net
  r = res('22'); r[1] += src; r[2] += sen

