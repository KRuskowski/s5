an = Net('LED_PWR_A'); r = res('270'); d = led()
r[1] += vdd33; r[2] += an; d[1] += an; d[2] += gnd
# Status LED on a T113 GPIO (active low)
stat = Net('LED_STATUS'); an = Net('LED_STA_A')
