#!/usr/bin/env python3
"""
V5: 5-port managed GbE PoE switch with Allwinner T113-S3.

KSZ9477S 7-port switch:
  - Ports 1-5: 10/100/1000 copper PHY -> LPJG0926HENL PoE+
    GbE MagJack (integrated magnetics + LEDs + PoE center taps).
  - Port 6: RGMII (MAC) -> Allwinner T113-S3 (management CPU).
  - Port 7: SGMII/SerDes -> left unused (terminated, S_REXT kept).

Allwinner T113-S3 (eLQFP128, 14x14x1.4mm) -- SiP 128MB DDR3, so
NO external DRAM and NO DDR signal layer. Manages the KSZ over
SPI0; debug UART0; USB; SPI boot flash. EMAC drives KSZ port 6
over RGMII from the PG bank (frees all 5 copper PHYs for users).

PoE PSE: 2x TPS23861 (4 channels each) covers all 5 ports.
24V DC in (Phoenix Contact pluggable terminal, 3-pin: +24V/GND/PE)
-> LM5122 boost (24V to 48V for PoE) + TPS54560 buck (24V to 5V)
-> LDO chain (3.3 / 2.5 / 1.2V for KSZ) + 0.9V buck (T113
VDD-CORE) + 1.8V LDO (VDD18-DRAM).

4-layer stackup intent (no external DDR3 routing).

Pin sources:
  T113-S3:   Allwinner T113-S3 Datasheet v1.6, sec 4.2/4.3.
             Real ball numbers; see T113S3_PINMAP.md.
  KSZ9477S:  DS00002392C Table 3-1.
  TPS54560/TPS23861: TI datasheets.

NOTE: only ONE dedicated T113 ground pin (AGND=91); the eLQFP128
exposed pad is the main GND return -- EP->GND is mandatory.
"""

import os, glob
# Delete any cached SKiDL backup lib to prevent stale part defs
# from overriding the inline Part() definitions below.
_here = os.path.dirname(os.path.abspath(__file__))
for _f in glob.glob(os.path.join(_here, '*_sklib.py')):
  os.remove(_f)

from skidl import *

# ============================================================
# Stable ref counters
# ============================================================
_cref = [0]
_rref = [0]
_lref = [0]
_qref = [0]
_ledref = [0]

def cap(value, fp='Capacitor_SMD:C_0402_1005Metric'):
  _cref[0] += 1
  c = Part(
    tool=SKIDL, name='C', ref_prefix='C',
    dest=NETLIST, value=value, footprint=fp,
    pins=[
      Pin(num='1', name='1', func=Pin.types.PASSIVE),
      Pin(num='2', name='2', func=Pin.types.PASSIVE),
    ])
  c.ref = f'C{_cref[0]}'
  return c

def res(value, fp='Resistor_SMD:R_0402_1005Metric'):
  _rref[0] += 1
  r = Part(
    tool=SKIDL, name='R', ref_prefix='R',
    dest=NETLIST, value=value, footprint=fp,
    pins=[
      Pin(num='1', name='1', func=Pin.types.PASSIVE),
      Pin(num='2', name='2', func=Pin.types.PASSIVE),
    ])
  r.ref = f'R{_rref[0]}'
  return r

def inductor(value, fp='Inductor_SMD:L_1210_3225Metric'):
  _lref[0] += 1
  l = Part(
    tool=SKIDL, name='L', ref_prefix='L',
    dest=NETLIST, value=value, footprint=fp,
    pins=[
      Pin(num='1', name='1', func=Pin.types.PASSIVE),
      Pin(num='2', name='2', func=Pin.types.PASSIVE),
    ])
  l.ref = f'L{_lref[0]}'
  return l

def led():
  """0603 LED: pin 1=A(anode), pin 2=K(cathode)."""
  _ledref[0] += 1
  d = Part(
    tool=SKIDL, name='LED', ref_prefix='D',
    dest=NETLIST,
    footprint='LED_SMD:LED_0603_1608Metric',
    pins=[
      Pin(num='1', name='A', func=Pin.types.PASSIVE),
      Pin(num='2', name='K', func=Pin.types.PASSIVE),
    ])
  d.ref = f'D{_ledref[0] + 2}'  # D1=SS54, D2=1N4148
  return d

def nfet(ref_des):
  """N-channel MOSFET in SOT-223: pin 1=G, 2=D(tab), 3=S."""
  _qref[0] += 1
  q = Part(
    tool=SKIDL, name='NMOS', ref_prefix='Q',
    dest=NETLIST,
    footprint='Package_TO_SOT_SMD:SOT-223-3_TabPin2',
    pins=[
      Pin(num='1', name='G', func=Pin.types.INPUT),
      Pin(num='2', name='D', func=Pin.types.PASSIVE),
      Pin(num='3', name='S', func=Pin.types.PASSIVE),
    ])
  q.ref = ref_des
  return q

def decouple(rail, gnd, n, value='100nF',
             fp='Capacitor_SMD:C_0402_1005Metric'):
  """Place n decoupling caps between rail and gnd."""
  for _ in range(n):
    c = cap(value, fp)
    c[1] += rail
    c[2] += gnd

# ============================================================
# Power nets
# ============================================================
vin24 = Net('VIN_24V')
vbus48 = Net('VBUS_48V')     # 48V PoE rail (from boost)
vdd5  = Net('VDD_5V')
earth = Net('PE')            # protective earth
vdd33 = Net('VDD_3V3')
vdd25 = Net('VDD_2V5')      # KSZ AVDDH/VDDHS
vdd12 = Net('VDD_1V2')      # KSZ core rails
vcore = Net('VDD_CORE')     # T113-S3 VDD-CORE 0.9V (buck)
vdd18 = Net('VDD_1V8')      # T113-S3 VDD18-DRAM (LDO)
gnd   = Net('GND')

# ============================================================
# Power input -- 3-pin Phoenix Contact pluggable terminal block
# Pin 1=+24V, pin 2=GND(0V), pin 3=PE(earth)
# MSTB 2,5/3-GF-5,08 (5.08mm pitch, 3-pin, horizontal,
# threaded flange for locking). Mates with MSTB 2,5/3-ST-5,08.
# Place at bottom board edge, rotate so wires exit downward.
# ============================================================
J1 = Part(
  tool=SKIDL, name='Conn_01x03', ref_prefix='J',
  dest=NETLIST,
  footprint='Connector_Phoenix_MSTB:'
            'PhoenixContact_MSTB_2,5_3-GF-5,08_1x03'
            '_P5.08mm_Horizontal_ThreadedFlange',
  pins=[
    Pin(num='1', name='24V',  func=Pin.types.PASSIVE),
    Pin(num='2', name='GND',  func=Pin.types.PASSIVE),
    Pin(num='3', name='PE',   func=Pin.types.PASSIVE),
  ])
J1.ref = 'J1'
J1[1] += vin24
J1[2] += gnd
J1[3] += earth    # PE routed to chassis/shield pad

# Input protection: 100uF bulk + TVS on 24V input
c = cap('100uF', 'Capacitor_SMD:C_1206_3216Metric')
c[1] += vin24; c[2] += gnd

# ============================================================
# LM5122 boost converter -- 24V to 48V for PoE rail
# WQFN-20 (4x4mm). Synchronous boost controller.
# Key pins: VIN=18, EN=17, HO=12, LO=14, SW=13,
#   BST=11, SS=7, COMP=5, FB=4, PGND=15, AGND=3, VCC=10
# ============================================================
U_BOOST = Part(
  tool=SKIDL, name='LM5122', ref_prefix='U', dest=NETLIST,
  footprint='Package_DFN_QFN:QFN-20-1EP_4x4mm_P0.5mm_EP2.7x2.7mm',
  pins=[
    Pin(num='1',  name='DEMB', func=Pin.types.INPUT),
    Pin(num='2',  name='ILIM', func=Pin.types.INPUT),
    Pin(num='3',  name='AGND', func=Pin.types.PWRIN),
    Pin(num='4',  name='FB',   func=Pin.types.INPUT),
    Pin(num='5',  name='COMP', func=Pin.types.PASSIVE),
    Pin(num='6',  name='RT',   func=Pin.types.PASSIVE),
    Pin(num='7',  name='SS',   func=Pin.types.PASSIVE),
    Pin(num='8',  name='SYNC', func=Pin.types.INPUT),
    Pin(num='9',  name='UVLO', func=Pin.types.INPUT),
    Pin(num='10', name='VCC',  func=Pin.types.PWROUT),
    Pin(num='11', name='BST',  func=Pin.types.PASSIVE),
    Pin(num='12', name='HO',   func=Pin.types.OUTPUT),
    Pin(num='13', name='SW',   func=Pin.types.PASSIVE),
    Pin(num='14', name='LO',   func=Pin.types.OUTPUT),
    Pin(num='15', name='PGND', func=Pin.types.PWRIN),
    Pin(num='16', name='CSP',  func=Pin.types.INPUT),
    Pin(num='17', name='EN',   func=Pin.types.INPUT),
    Pin(num='18', name='VIN',  func=Pin.types.PWRIN),
    Pin(num='19', name='PG',   func=Pin.types.OPENCOLL),
    Pin(num='20', name='CSN',  func=Pin.types.INPUT),
    Pin(num='21', name='EP',   func=Pin.types.PASSIVE),
  ])
U_BOOST.ref = 'U14'
U_BOOST[18] += vin24        # VIN
U_BOOST[17] += vin24        # EN (on when input present)
U_BOOST[3]  += gnd          # AGND
U_BOOST[15] += gnd          # PGND
U_BOOST[21] += gnd          # EP
U_BOOST[1]  += gnd          # DEMB (GND = forced CCM)
U_BOOST[8]  += gnd          # SYNC (GND = internal clock)
# VCC bypass
decouple(Net('BOOST_VCC'), gnd, 1, '4.7uF',
         'Capacitor_SMD:C_0805_2012Metric')
U_BOOST[10] += Net('BOOST_VCC')
# Bootstrap cap
bst_net = Net('BST_BOOST')
U_BOOST[11] += bst_net
boost_sw = Net('BOOST_SW')
U_BOOST[13] += boost_sw
c = cap('100nF'); c[1] += bst_net; c[2] += boost_sw
# High/low gate drive -> external FETs (simplified: using
# integrated FET topology or external N-FETs — TO BE REFINED
# per LM5122 reference design. For now, nets are named.)
U_BOOST[12] += Net('BOOST_HO')   # high-side gate
U_BOOST[14] += Net('BOOST_LO')   # low-side gate
# Current sense across inductor
U_BOOST[16] += Net('BOOST_CSP')  # sense +
U_BOOST[20] += Net('BOOST_CSN')  # sense -
# Soft-start
c = cap('100nF'); c[1] += Net('BOOST_SS'); c[2] += gnd
U_BOOST[7] += Net('BOOST_SS')
# Frequency set (200kHz: RT ~150k per datasheet)
r = res('150k'); r[1] += Net('BOOST_RT'); r[2] += gnd
U_BOOST[6] += Net('BOOST_RT')
# UVLO: set for 20V turn-on (divider from VIN)
uvlo_net = Net('BOOST_UVLO')
U_BOOST[9] += uvlo_net
r = res('100k'); r[1] += vin24; r[2] += uvlo_net
r = res('6.8k'); r[1] += uvlo_net; r[2] += gnd
# ILIM: set with resistor to GND (per datasheet)
r = res('33k'); r[1] += Net('BOOST_ILIM'); r[2] += gnd
U_BOOST[2] += Net('BOOST_ILIM')
# FB divider for 48V output (1.227V ref):
# R_top/R_bot = (48-1.227)/1.227 = 38.1 -> 383k/10k
boost_fb = Net('BOOST_FB'); U_BOOST[4] += boost_fb
r = res('383k'); r[1] += vbus48; r[2] += boost_fb
r = res('10k'); r[1] += boost_fb; r[2] += gnd
# Compensation: 10nF + 10k series from COMP (tune per app note)
boost_comp = Net('BOOST_COMP'); U_BOOST[5] += boost_comp
r = res('10k'); r[1] += boost_comp
bc_mid = Net('BOOST_COMP_MID'); r[2] += bc_mid
c = cap('10nF'); c[1] += bc_mid; c[2] += gnd
# Power good (open drain, pull up)
r = res('100k'); r[1] += vin24; r[2] += Net('BOOST_PG')
U_BOOST[19] += Net('BOOST_PG')
# Boost output inductor (10uH, high current)
l = inductor('10uH', 'Inductor_SMD:L_1210_3225Metric')
l[1] += vin24; l[2] += boost_sw
# Output caps on 48V rail
for _ in range(3):
  c = cap('10uF', 'Capacitor_SMD:C_1206_3216Metric')
  c[1] += vbus48; c[2] += gnd
# Input caps on 24V
for _ in range(2):
  c = cap('22uF', 'Capacitor_SMD:C_1206_3216Metric')
  c[1] += vin24; c[2] += gnd

# ============================================================
# TPS54560 buck converter -- 24V to 5V, SOIC-8+EP
# (Vin range 4.5-60V, works from 24V directly)
# ============================================================
U6 = Part(
  tool=SKIDL, name='TPS54560', ref_prefix='U',
  dest=NETLIST,
  footprint='Package_SO:'
            'SOIC-8-1EP_3.9x4.9mm_P1.27mm_EP2.29x3mm',
  pins=[
    Pin(num='1', name='BOOT',   func=Pin.types.PASSIVE),
    Pin(num='2', name='VIN',    func=Pin.types.PWRIN),
    Pin(num='3', name='EN',     func=Pin.types.INPUT),
    Pin(num='4', name='SS_TR',  func=Pin.types.PASSIVE),
    Pin(num='5', name='VSENSE', func=Pin.types.INPUT),
    Pin(num='6', name='COMP',   func=Pin.types.PASSIVE),
    Pin(num='7', name='GND',    func=Pin.types.PWRIN),
    Pin(num='8', name='PH',     func=Pin.types.PWROUT),
    Pin(num='9', name='EP',     func=Pin.types.PASSIVE),
  ])
U6.ref = 'U6'

sw_node = Net('SW_NODE')
U6[2] += vin24
U6[7] += gnd
U6[9] += gnd
U6[3] += vin24  # EN tied to VIN (always on)
U6[8] += sw_node

# Bootstrap cap: 100nF from BOOT to PH
c = cap('100nF'); c[1] += Net('BOOT'); c[2] += sw_node
U6[1] += c[1]
# Soft-start: 100nF to GND
c = cap('100nF'); c[1] += Net('SS_TR'); c[2] += gnd
U6[4] += c[1]
# Compensation: 15nF + 24.9k series from COMP
comp_net = Net('COMP'); U6[6] += comp_net
r = res('24.9k'); r[1] += comp_net
comp_mid = Net('COMP_MID'); r[2] += comp_mid
c = cap('15nF'); c[1] += comp_mid; c[2] += gnd
# Input caps: 2x 2.2uF/100V
for _ in range(2):
  c = cap('2.2uF', 'Capacitor_SMD:C_1206_3216Metric')
  c[1] += vin24; c[2] += gnd
# Schottky SS54: cathode to SW_NODE, anode to GND
D1 = Part(
  tool=SKIDL, name='SS54', ref_prefix='D',
  dest=NETLIST, value='SS54', footprint='Diode_SMD:D_SMA',
  pins=[
    Pin(num='1', name='K', func=Pin.types.PASSIVE),
    Pin(num='2', name='A', func=Pin.types.PASSIVE),
  ])
D1.ref = 'D1'
D1[1] += sw_node; D1[2] += gnd
# Output inductor 33uH, output caps 2x 22uF
l = inductor('33uH'); l[1] += sw_node; l[2] += vdd5
for _ in range(2):
  c = cap('22uF', 'Capacitor_SMD:C_0805_2012Metric')
  c[1] += vdd5; c[2] += gnd
# Feedback divider 52.3k/10k for 5V (0.8V ref)
fb_net = Net('FB_5V'); U6[5] += fb_net
r = res('52.3k'); r[1] += vdd5; r[2] += fb_net
r = res('10k'); r[1] += fb_net; r[2] += gnd

# ============================================================
# LDO regulators
# ============================================================
def ldo_sot223(name, ref_des):
  """SOT-223 LDO: pin 1=GND, pin 2=VO, pin 3=VI."""
  u = Part(
    tool=SKIDL, name=name, ref_prefix='U', dest=NETLIST,
    footprint='Package_TO_SOT_SMD:SOT-223-3_TabPin2',
    pins=[
      Pin(num='1', name='GND', func=Pin.types.PWRIN),
      Pin(num='2', name='VO',  func=Pin.types.PWROUT),
      Pin(num='3', name='VI',  func=Pin.types.PWRIN),
    ])
  u.ref = ref_des
  return u

def ldo_sot23(name, ref_des):
  """SOT-23-5 LDO (AP2112K): 1=VIN,2=GND,3=EN,5=VOUT."""
  u = Part(
    tool=SKIDL, name=name, ref_prefix='U', dest=NETLIST,
    footprint='Package_TO_SOT_SMD:SOT-23-5',
    pins=[
      Pin(num='1', name='VIN',  func=Pin.types.PWRIN),
      Pin(num='2', name='GND',  func=Pin.types.PWRIN),
      Pin(num='3', name='EN',   func=Pin.types.INPUT),
      Pin(num='4', name='NC',   func=Pin.types.NOCONNECT),
      Pin(num='5', name='VOUT', func=Pin.types.PWROUT),
    ])
  u.ref = ref_des
  return u

# U2: AMS1117-3.3 (5V -> 3.3V)
U2 = ldo_sot223('AMS1117-3.3', 'U2')
U2[3] += vdd5; U2[2] += vdd33; U2[1] += gnd
# U3: AP2112K-2.5 (3.3V -> 2.5V, KSZ AVDDH/VDDHS)
U3 = ldo_sot23('AP2112K-2.5', 'U3')
U3[1] += vdd33; U3[2] += gnd; U3[3] += vdd33; U3[5] += vdd25
# U4: AP2112K-1.2 (3.3V -> 1.2V, KSZ + H3 VDD_SYS/CPUS)
# NOTE: combined 1.2V load may approach AP2112K 600mA limit;
# upgrade to a 1.2V buck if bench current is high.
U4 = ldo_sot23('AP2112K-1.2', 'U4')
U4[1] += vdd33; U4[2] += gnd; U4[3] += vdd33; U4[5] += vdd12

# ============================================================
# 0.9V core rail -- TLV62569 buck (5V -> 0.9V), SOT-23-6
# for T113-S3 VDD-CORE. Pin 1=SW,2=GND,3=EN,4=FB,5=VIN,6=MODE
# ============================================================
U11 = Part(
  tool=SKIDL, name='TLV62569', ref_prefix='U', dest=NETLIST,
  footprint='Package_TO_SOT_SMD:SOT-23-6',
  pins=[
    Pin(num='1', name='SW',   func=Pin.types.PWROUT),
    Pin(num='2', name='GND',  func=Pin.types.PWRIN),
    Pin(num='3', name='EN',   func=Pin.types.INPUT),
    Pin(num='4', name='FB',   func=Pin.types.INPUT),
    Pin(num='5', name='VIN',  func=Pin.types.PWRIN),
    Pin(num='6', name='MODE', func=Pin.types.INPUT),
  ])
U11.ref = 'U11'
U11[5] += vdd5
U11[2] += gnd
U11[3] += vdd5   # EN on
U11[6] += gnd    # MODE: PFM/PWM auto
core_sw = Net('CORE_SW')
U11[1] += core_sw
l = inductor('1uH', 'Inductor_SMD:L_0805_2012Metric')
l[1] += core_sw; l[2] += vcore
decouple(vdd5, gnd, 1, '10uF', 'Capacitor_SMD:C_0805_2012Metric')
for _ in range(2):
  c = cap('22uF', 'Capacitor_SMD:C_0805_2012Metric')
  c[1] += vcore; c[2] += gnd
# FB divider for 0.9V (0.6V ref): R_top/R_bot=(0.9-0.6)/0.6=0.5
fb09 = Net('FB_0V9'); U11[4] += fb09
r = res('50k');  r[1] += vcore; r[2] += fb09
r = res('100k'); r[1] += fb09;  r[2] += gnd

# ============================================================
# 1.8V rail -- AP2112K-1.8 LDO (3.3V -> 1.8V) for T113
# VDD18-DRAM (SiP DDR3 I/O; low current).
# ============================================================
U12 = ldo_sot23('AP2112K-1.8', 'U12')
U12[1] += vdd33; U12[2] += gnd; U12[3] += vdd33; U12[5] += vdd18
for _ in range(2):
  c = cap('10uF', 'Capacitor_SMD:C_0805_2012Metric')
  c[1] += vdd18; c[2] += gnd

# Bulk caps per rail
for rail in [vin24, vdd5, vdd33, vdd25, vdd12, vcore, vdd18]:
  c = cap('10uF', 'Capacitor_SMD:C_0805_2012Metric')
  c[1] += rail; c[2] += gnd

# ============================================================
# KSZ9477S -- 128-TQFP-EP, DS00002392C
# ============================================================
U1 = Part(
  tool=SKIDL, name='KSZ9477S', ref_prefix='U', dest=NETLIST,
  footprint='chips:QFP40P1600X1600X120-129N',
  pins=[
    Pin(num=str(i), name=f'P{i}', func=Pin.types.BIDIR)
    for i in range(1, 129)
  ] + [
    Pin(num='129', name='EP', func=Pin.types.PASSIVE),
  ] + [
    Pin(num=f'E_{i}', name=f'EP_{i}', func=Pin.types.PASSIVE)
    for i in range(1, 65)
  ])
U1.ref = 'U1'

# KSZ9477S power pins
for p in [3, 14, 19, 30, 36, 41, 114, 119, 124]:  # AVDDL 1.2
  U1[p] += vdd12
for p in [10, 22, 33, 44, 111, 122, 128]:          # AVDDH 2.5
  U1[p] += vdd25
for p in [11, 23, 45, 56, 66, 70, 87, 104, 110]:   # DVDDL 1.2
  U1[p] += vdd12
for p in [61, 68, 99]:                              # VDDIO 3.3
  U1[p] += vdd33
for p in [71, 84]:                                  # VDDLS 1.2
  U1[p] += vdd12
for p in [72, 83]:                                  # VDDHS 2.5
  U1[p] += vdd25
for p in [46, 47, 69, 75, 77, 80, 107, 109, 123, 129]:  # GND
  U1[p] += gnd
for i in range(1, 65):                              # EP segments
  U1[f'E_{i}'] += gnd

# KSZ decoupling: 9x2.5V, 20x1.2V, 3x3.3V
decouple(vdd25, gnd, 9)
decouple(vdd12, gnd, 20)
decouple(vdd33, gnd, 3)

# KSZ crystal 25MHz
Y1 = Part(
  tool=SKIDL, name='Crystal_25MHz', ref_prefix='Y',
  dest=NETLIST, value='25MHz',
  footprint='Crystal:Crystal_SMD_2016-4Pin_2.0x1.6mm',
  pins=[
    Pin(num='1', name='1', func=Pin.types.PASSIVE),
    Pin(num='2', name='2', func=Pin.types.PASSIVE),
  ])
xi = Net('KSZ_XI'); xo = Net('KSZ_XO')
U1[126] += xi; U1[125] += xo
Y1[1] += xi; Y1[2] += xo
c = cap('15pF'); c[1] += xi; c[2] += gnd
c = cap('15pF'); c[1] += xo; c[2] += gnd

# KSZ reference resistors
r = res('6.04k'); iset = Net('KSZ_ISET'); r[1] += iset; r[2] += gnd
U1[127] += iset
r = res('191'); srext = Net('KSZ_S_REXT'); r[1] += srext; r[2] += gnd
U1[76] += srext   # port-7 SerDes S_REXT (kept even though P7 unused)

# KSZ reset RC + diode
reset_net = Net('KSZ_RESET_N'); U1[96] += reset_net
r = res('10k'); r[1] += vdd33; r[2] += reset_net
c = cap('10uF', 'Capacitor_SMD:C_0805_2012Metric')
c[1] += reset_net; c[2] += gnd
D2 = Part(
  tool=SKIDL, name='D_1N4148', ref_prefix='D',
  dest=NETLIST, value='1N4148', footprint='Diode_SMD:D_SOD-323',
  pins=[
    Pin(num='1', name='K', func=Pin.types.PASSIVE),
    Pin(num='2', name='A', func=Pin.types.PASSIVE),
  ])
D2.ref = 'D2'
D2[2] += reset_net; D2[1] += vdd33

# KSZ SPI management (to H3 SPI0) + INT
spi_clk  = Net('SPI_CLK')
