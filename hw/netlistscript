generate_netlist(file_='netlist_s5.net')

import re, hashlib, uuid
with open('netlist_s5.net', 'r') as f:
  content = f.read()
counter = [0]
def stable_replace_tstamp(m):
  counter[0] += 1
  h = hashlib.md5(f'tstamp_{counter[0]}'.encode()).hexdigest()
  return f'(tstamps "{uuid.UUID(h)}")'
counter_tag = [0]
def stable_replace_tag(m):
  counter_tag[0] += 1
  return f'(name "SKiDL Tag") "tag_{counter_tag[0]}")'
content = re.sub(r'\(tstamps "[^"]+"\)',
                 stable_replace_tstamp, content)
content = re.sub(r'\(name "SKiDL Tag"\) "[^"]+"\)',
                 stable_replace_tag, content)
with open('netlist_s5.net', 'w') as f:
  f.write(content)

